{
  "name": "punchme",
  "version": "1.0.0",
  "description": "party joke game",
  "scripts": {
    "dev": "docker compose up -d mongo ollama && concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd api && npm run dev",
    "dev:web": "cd web && npm run dev",
    "infra": "docker compose up -d mongo ollama",
    "infra:stop": "docker compose down",
    "setup": "docker compose --profile setup run --rm model-pull",
    "docker": "docker compose --profile production up --build -d",
    "docker:tunnel": "docker compose --profile production --profile tunnel up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=200",
    "ngrok:up": "ngrok http 5173",
    "ngrok:url": "node scripts/ngrok-url.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
